<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.drivecheaper.controllers.MitarbeiterController">
   <center>
      <TableView fx:id="tabelleFahrzeuge" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colId" prefWidth="-1.0" text="ID" />
            <TableColumn fx:id="colStatus" prefWidth="-1.0" text="Status" />
          <TableColumn fx:id="colHersteller" prefWidth="-1.0" text="Hersteller" />
            <TableColumn fx:id="colModell" prefWidth="-1.0" text="Modell" />
            <TableColumn fx:id="colKennzeichen" prefWidth="-1.0" text="Kennzeichen" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
   <left>
      <HBox BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="TOP_CENTER" prefWidth="200.0" spacing="8.0">
               <children>
                  <Label text="Hersteller" />
                  <TextField fx:id="txtHersteller" alignment="TOP_LEFT" />
                  <Label text="Modell" />
                  <TextField fx:id="txtModell" />
                  <Label text="Kennzeichen" />
                  <TextField fx:id="txtKennzeichen" />
                  <Separator prefWidth="200.0" />
                  <Button fx:id="btnNeue" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onHizufugenKlicken" text="Hinzufügen" />
                  <Separator prefWidth="200.0" />
                  <Button fx:id="btnBearbeiten" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onBearbeitenKlicken" text="Bearbeiten" />
                  <Separator prefWidth="200.0" />
                  <Button fx:id="btnLoeschen" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onLoeschenKlicken" text="Löschen" />
                  <Separator prefWidth="200.0" />
                  <Button fx:id="btnAbbrechen" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onAbbrechenKlicken" text="Abbrechen" />
               </children>
               <padding>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </padding>
            </VBox>
            <Separator orientation="VERTICAL" prefHeight="200.0" />
         </children>
      </HBox>
   </left>
   <top>
      <Separator prefWidth="200.0" BorderPane.alignment="CENTER" />
   </top>
   <bottom>
      <Separator prefWidth="200.0" BorderPane.alignment="CENTER" />
   </bottom>
   <right>
      <Separator orientation="VERTICAL" prefHeight="200.0" BorderPane.alignment="CENTER" />
   </right>
</BorderPane>
